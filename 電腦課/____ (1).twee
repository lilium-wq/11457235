:: StoryStylesheet [stylesheet]
body {
  background: linear-gradient(to right, #e8d0d5, #cfd8e6);
  font-family: "Noto Serif TC", serif;
}

/* 中央卡片 */
.menu-card {
  background: white;
  width: 500px;
  margin: 80px auto;
  padding: 30px;
  border-radius: 15px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.2);
  text-align: center;
}

.menu-card img {
  width: 80%;
  border-radius: 10px;
  margin: 15px 0;
}

.menu-card h1 {
  color: #5a3e36;
  font-size: 28px;
  margin-bottom: 10px;
}

.menu-card p {
  color: #666;
  font-size: 16px;
  
  line-height: 1.6;
}

.menu-button {
  background: #7da0d6;
  color: white;
  padding: 12px;
  margin: 10px auto;
  width: 240px;
  border-radius: 10px;
  cursor: pointer;
  transition: 0.3s;
  
  font-weight: bold;
  letter-spacing: 2px;
}

.menu-button:hover {
  background: #5a7db5;
  transform: scale(1.05);
}

hr {
  width: 60%;
  border: 1px solid #ddd;
  margin: 15px auto;
}

.menu-card {
  animation: fadeIn 1s;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}


.menu-card p {
  line-height: 1.8;
}

.menu-card p[style*="text-align:left"] {
  padding-left: 20px;
}

a {
  color: inherit;
  text-decoration: none;
}

a:visited {
  color: inherit;
}

.menu-card h2 {
  color: #5a3e36;
  font-weight: bold;
  margin-top: 20px;
}

.menu-card p {
  line-height: 1.6;
  margin: 8px 0;
}

.word {
  color: #4a6fa5;
  cursor: pointer;
  font-weight: bold;
}

.word:hover {
  text-decoration: underline;
}

.word-box {
  background: #f3f6fb;
  padding: 10px;
  margin-top: 8px;
  border-radius: 8px;
  font-size: 14px;
}

.word-box {
  position: absolute;
  background: white;
  border: 1px solid #ccc;
  padding: 10px;
  border-radius: 8px;
  width: 220px;
  font-size: 14px;
  box-shadow: 0px 4px 12px rgba(0,0,0,0.2);

  margin-top: 5px;
  z-index: 10;
}

.word {
  position: relative;
}

.word-tag {
  display: inline-block;
  background: #7da0d6;
  color: white;
  padding: 5px 10px;
  margin: 5px;
  border-radius: 12px;
  font-size: 14px;
}

.menu-card p {
  margin: 6px 0;
  line-height: 1.8;
}

.progress-box {
  background: #f4f7fb;
  padding: 12px;
  border-radius: 10px;
  margin-top: 10px;
  margin-bottom: 10px;
  text-align: left;
  font-size: 14px;
}

.menu-card a {
  color: #4a6fa5;
  font-weight: bold;
}

.menu-card {
  color: #333;
}

.menu-card a {
  color: #4a6fa5;
  font-weight: bold;
}

.menu-card p {
  line-height: 1.5;
  margin: 10px 0;
}